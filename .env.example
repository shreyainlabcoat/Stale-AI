# Optional. Without this key, Stale AI runs in deterministic demo mode.
OPENAI_API_KEY=

# Set this explicitly to a model your account can call before a live demo.
OPENAI_MODEL=gpt-4o-mini

# Restrict repository scanning and Codex edits to this directory.
# By default, the project directory is used.
STALEAI_ALLOWED_ROOT=

# Codex executable, if it is not already on PATH.
CODEX_BIN=codex

# Speed up the bundled hackathon demo: defaults runs_per_eval to 1, skips the
# semantic judge, and runs the bundled sample_target_openai agent with its
# deterministic notes-based response instead of a live OpenAI call. Source
# analysis and eval generation still use the OpenAI API when a key is set.
STALEAI_FAST_DEMO=true

# Independently enable/disable the OpenAI semantic judge without turning on
# every fast demo behavior. Fast demo mode always disables the judge
# regardless of this setting.
STALEAI_SEMANTIC_JUDGE=false
