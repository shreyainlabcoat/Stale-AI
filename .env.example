# Optional. Without this key, Stale AI runs in deterministic demo mode.
OPENAI_API_KEY=

# GPT-5.6 alias. Change only if your account uses a different available model.
OPENAI_MODEL=gpt-5.6

# Restrict repository scanning and Codex edits to this directory.
# By default, the project directory is used.
STALEAI_ALLOWED_ROOT=

# Codex executable, if it is not already on PATH.
CODEX_BIN=codex
